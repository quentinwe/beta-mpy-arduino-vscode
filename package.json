{
  "name": "beta-micropython-for-arduino",
  "displayName": "[Deprecated beta] MicroPython for Arduino",
  "description": "MicroPython development tools for Arduino boards",
  "publisher": "BA26-mpy-vscode",
  "version": "0.0.6",
  "engines": {
    "vscode": "^1.109.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/quentinwe/beta-mpy-arduino-vscode"
  },
  "icon": "media/warn-1.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "package": "npx @vscode/vsce package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "npm run test:unit && npm run test:integration",
    "typecheck": "tsc --noEmit",
    "test:unit": "jest --testPathPattern=src/test/unit --coverage --passWithNoTests",
    "test:integration": "jest --testPathPattern=src/test/integration --passWithNoTests",
    "prettier": "prettier --check src",
    "check-duplicates": "jscpd ./media ./src --reporters html,csv --output report/"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "jest-junit": "^17.0.0",
    "jscpd": "^4.0.5",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
